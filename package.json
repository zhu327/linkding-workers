{
  "name": "linkding-workers",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && npm run build:css",
    "build:css": "npm run build:css:light && npm run build:css:dark",
    "build:css:light": "postcss -o public/css/theme-light.css styles/theme-light.css",
    "build:css:dark": "postcss -o public/css/theme-dark.css styles/theme-dark.css",
    "test": "vitest run",
    "lint": "eslint src test",
    "dev": "wrangler dev"
  },
  "dependencies": {
    "hono": "^4.12.27",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/runner": "^4.1.9",
    "@vitest/snapshot": "^4.1.9",
    "cssnano": "^7.0.6",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
